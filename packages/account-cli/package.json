{
  "name": "@base-org/account-cli",
  "version": "0.1.0",
  "description": "Base Account CLI — agent-first CLI for interacting with Base Accounts",
  "keywords": [
    "base",
    "account",
    "cli",
    "agent",
    "web3"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "base-account": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "repository": "https://github.com/base/account-sdk.git",
  "author": "Base",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf dist && rm -rf node_modules",
    "test": "vitest run",
    "prebuild": "rm -rf ./dist",
    "build": "tsc -p ./tsconfig.build.json",
    "postbuild": "printf '#!/usr/bin/env node\n' | cat - dist/index.js > dist/index.tmp && mv dist/index.tmp dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "format:check": "biome check . --formatter-enabled=true --linter-enabled=false --organize-imports-enabled=false"
  },
  "dependencies": {
    "@base-org/account": "workspace:*",
    "commander": "^13.0.0",
    "viem": "^2.31.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.1.6",
    "vitest": "^2.1.9"
  }
}
